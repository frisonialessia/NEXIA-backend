# Orígenes permitidos por CORS (coma-separados). "*" para desarrollo.
# En producción, restringe a tu dominio de Vercel:
# NEXIA_CORS_ORIGINS=https://nexia-frontend.vercel.app
NEXIA_CORS_ORIGINS=*

# Puerto (lo inyecta la plataforma de hosting; por defecto 8000 en local).
# PORT=8000

# ── Auth / multi-tenant (FASE 2) ────────────────────────────────────────────
# Exigir login Bearer en el API. DESACTIVADA por defecto (modo demo abierto, con
# una sola organización por defecto = comportamiento de FASE 1). Actívala a la
# vez que NEXT_PUBLIC_AUTH=remote en el frontend.
# NEXIA_AUTH=1
# Clave de firma del JWT. OBLIGATORIA si NEXIA_AUTH=1: el backend NO arranca si
# falta o usa el valor de desarrollo (fail-fast de seguridad). Pon algo largo y
# aleatorio (p. ej. `openssl rand -hex 32`).
# NEXIA_JWT_SECRET=cambia-esto-por-un-secreto-largo-y-aleatorio
# Validez del token en horas (default 12).
# NEXIA_JWT_TTL_H=12

# ── Persistencia local (opcional, $0, sin servicios) ────────────────────────
# Por defecto el estado vive en memoria (se pierde al reiniciar). Para persistir
# a un fichero SQLite local (cero coste, sobrevive reinicios):
# NEXIA_SQLITE_PATH=nexia_estado.db
# (o NEXIA_PERSIST=1 para usar ./nexia_estado.db por defecto)
# Nota: en hosting de disco efímero (free tier) el fichero se resetea al redeployar.

# ── Modo demo (ROI sembrado para que no arranque en 0) ───────────────────────
# Siembra el libro de etiquetas con 2 alertas YA confirmadas como 'real' (ejemplo)
# para que el ROI REAL calcule un ahorro creíble (~$24k) DESDE esas etiquetas (no
# inventado). El frontend las marca como 'ejemplo' (NEXT_PUBLIC_DEMO). Apagado por
# defecto → arranque honesto en 0.
# NEXIA_DEMO=1

# ── Fuente de datos (módulo de ingesta) ────────────────────────────────────
# sim  (por defecto) → simulador interno (no requiere hardware)
# csv                → reproduce un CSV de lecturas (prueba del pipeline)
# mqtt               → escucha un broker MQTT real (gateway que publica)
# opcua              → lee un PLC / gateway industrial por OPC UA
NEXIA_SOURCE=sim

# Telemetría multi-variable en el simulador (temp, pres, rpm, caudal, corriente).
# ACTIVADA por defecto (para ver multi-variable en vivo). Pon 0 para emitir solo
# vibración (payload idéntico al de antes de multi-variable).
# NEXIA_SIM_MULTIVAR=0

# Conectores reales requieren: pip install -r requirements-ingest.txt

# Modo csv:
# NEXIA_CSV_PATH=app/ingest/sample_readings.csv
# Con varias magnitudes (columnas extra: temp, pres, rpm, caudal, corriente):
# NEXIA_CSV_PATH=app/ingest/sample_readings_multi.csv
# NEXIA_CSV_INTERVALO_S=2

# Modo mqtt:
# MQTT_HOST=broker.planta.local
# MQTT_PORT=1883
# MQTT_TOPIC=nexia/+/vibracion
# MQTT_USER=usuario
# MQTT_PASS=secreto

# Modo opcua (PLC). El mapeo de nodos se edita en opcua_source.py o aquí (JSON).
# 'campo' usa el vocabulario canónico (app/constants.py): 'vib' es el pivote y el
# resto (temp, pres, rpm, caudal, corriente) son magnitudes de telemetría. Los
# nodos de una misma máquina se agrupan y se emiten en una sola lectura.
# OPCUA_URL=opc.tcp://192.168.0.10:4840
# OPCUA_INTERVALO_S=2
# OPCUA_USER=usuario
# OPCUA_PASS=secreto
# OPCUA_NODES=[{"node":"ns=2;i=1001","maquina":"Bomba de agua cruda","campo":"vib"},{"node":"ns=2;i=1002","maquina":"Bomba de agua cruda","campo":"temp"}]
